{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "paths": {
      "@prestili/shared": ["./packages/shared/src"],
      "@prestili/database": ["./packages/database/src"],
      "@prestili/canvas": ["./packages/canvas/src"],
      "@prestili/ai": ["./packages/ai/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "out"]
}
